# Copia este archivo como .env y llénalo con tus valores
# En Railway, configura estas variables en el panel de Variables

# ID del Google Sheet (lo encuentras en la URL: /spreadsheets/d/ESTE_ID/edit)
GOOGLE_SHEET_ID=tu_sheet_id_aqui

# Nombre exacto de la pestaña en el Google Sheet
WORKSHEET_NAME=Cartera Total

# Opción A: JSON completo de las credenciales de la Service Account (recomendado para Railway)
# Pega todo el contenido del archivo credentials.json como una sola línea
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# Opción B: Ruta al archivo credentials.json (para desarrollo local)
# GOOGLE_CREDENTIALS_FILE=credentials.json
