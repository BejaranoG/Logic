# Copia este archivo como .env y llénalo con tus valores
# En Railway, configura estas variables en el panel de Variables

# ID del Google Sheet (lo encuentras en la URL: /spreadsheets/d/ESTE_ID/edit)
GOOGLE_SHEET_ID=tu_sheet_id_aqui

# Nombre exacto de la pestaña en el Google Sheet
WORKSHEET_NAME=Cartera Total

# ─────────────────────────────────────────────────────────────
# IMPORTANTE: El sheet debe estar publicado públicamente
# Pasos para publicarlo:
#   1. Abre el Google Sheet
#   2. Archivo → Compartir → Publicar en la web
#   3. Selecciona la hoja "Cartera Total" y formato "Valores separados por comas (.csv)"
#   4. Haz clic en "Publicar" y confirma
# No necesitas compartir el sheet con nadie ni crear credenciales.
# ─────────────────────────────────────────────────────────────

